rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 共通関数：ログイン済みかチェック
    function isAuthenticated() {
      return request.auth != null;
    }

    // 案件（projects）コレクション
    match /projects/{projectId} {
      // 読み取り：自分の案件のみ
      allow read: if isAuthenticated() && request.auth.uid == resource.data.ownerId;
      
      // 作成：自分のUIDをownerIdとして保存する場合のみ許可
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.ownerId;
      
      // 更新・削除：既存データの所有者が自分であること
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    // 予定（schedules）コレクション
    match /schedules/{scheduleId} {
      // 案1：プロジェクトIDを元に権限をチェックする場合（推奨）
      // 予定ドキュメント内に projectId が含まれている前提
      allow read, write: if isAuthenticated() && 
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.ownerId == request.auth.uid;

      /* 案2：もし「誰でも見れるが、編集は自分だけ」にしたい場合
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == resource.data.ownerId;
      */
    }
  }
}
